<!DOCTYPE html>
<html>
<head>

<meta charset="UTF-8">
<title>Talk With 2D</title>

<link rel="stylesheet" href="style.css">

</head>

<body>

<h1>Talk With 2D</h1>

<div id="controls">

<label>
<input type="checkbox" id="voiceToggle">
Voice Responses
</label>

<label>
<input type="checkbox" id="singToggle">
Occasional Singing
</label>

<label>
<input type="checkbox" id="musicToggle" onchange="toggleMusic()">
Background Music
</label>

<button onclick="startListening()">🎤 Talk</button>

</div>

<audio id="bgMusic" loop>
<source src="music.mp3" type="audio/mpeg">
</audio>

<div id="chatbox"></div>

<div id="typing" class="typing hidden">
2D is typing...
</div>

<div id="inputArea">

<input id="input" placeholder="Talk to 2D...">

<button onclick="send()">Send</button>

</div>

<script src="script.js"></script>

</body>
</html>

body{
